with "config/real_time_task_scheduling_and_delay_config.gpr";
project Real_Time_Task_Scheduling_And_Delay is

   for Source_Dirs use ("src/", "config/");
   for Object_Dir use "obj/" & Real_Time_Task_Scheduling_And_Delay_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("real_time_task_scheduling_and_delay.adb");

   package Compiler is
      for Default_Switches ("Ada") use Real_Time_Task_Scheduling_And_Delay_Config.Ada_Compiler_Switches;
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es"); --  Symbolic traceback
   end Binder;

   package Install is
      for Artifacts (".") use ("share");
   end Install;

end Real_Time_Task_Scheduling_And_Delay;
