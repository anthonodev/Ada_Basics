with "config/data_types_and_subtype_declarations_config.gpr";
project Data_Types_And_Subtype_Declarations is

   for Source_Dirs use ("src/", "config/");
   for Object_Dir use "obj/" & Data_Types_And_Subtype_Declarations_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("data_types_and_subtype_declarations.adb");

   package Compiler is
      for Default_Switches ("Ada") use Data_Types_And_Subtype_Declarations_Config.Ada_Compiler_Switches;
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es"); --  Symbolic traceback
   end Binder;

   package Install is
      for Artifacts (".") use ("share");
   end Install;

end Data_Types_And_Subtype_Declarations;
