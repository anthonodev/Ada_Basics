with "config/visibility_rules_and_use_clauses_config.gpr";
project Visibility_Rules_And_Use_Clauses is

   for Source_Dirs use ("src/", "config/");
   for Object_Dir use "obj/" & Visibility_Rules_And_Use_Clauses_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("visibility_rules_and_use_clauses.adb");

   package Compiler is
      for Default_Switches ("Ada") use Visibility_Rules_And_Use_Clauses_Config.Ada_Compiler_Switches;
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es"); --  Symbolic traceback
   end Binder;

   package Install is
      for Artifacts (".") use ("share");
   end Install;

end Visibility_Rules_And_Use_Clauses;
