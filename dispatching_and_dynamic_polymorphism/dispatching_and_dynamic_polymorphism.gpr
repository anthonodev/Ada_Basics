with "config/dispatching_and_dynamic_polymorphism_config.gpr";
project Dispatching_And_Dynamic_Polymorphism is

   for Source_Dirs use ("src/", "config/");
   for Object_Dir use "obj/" & Dispatching_And_Dynamic_Polymorphism_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("dispatching_and_dynamic_polymorphism.adb");

   package Compiler is
      for Default_Switches ("Ada") use Dispatching_And_Dynamic_Polymorphism_Config.Ada_Compiler_Switches;
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es"); --  Symbolic traceback
   end Binder;

   package Install is
      for Artifacts (".") use ("share");
   end Install;

end Dispatching_And_Dynamic_Polymorphism;
