with "config/variable_declarations_and_control_flow_config.gpr";
project Variable_Declarations_And_Control_Flow is

   for Source_Dirs use ("src/", "config/");
   for Object_Dir use "obj/" & Variable_Declarations_And_Control_Flow_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("variable_declarations_and_control_flow.adb");

   package Compiler is
      for Default_Switches ("Ada") use Variable_Declarations_And_Control_Flow_Config.Ada_Compiler_Switches;
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es"); --  Symbolic traceback
   end Binder;

   package Install is
      for Artifacts (".") use ("share");
   end Install;

end Variable_Declarations_And_Control_Flow;
