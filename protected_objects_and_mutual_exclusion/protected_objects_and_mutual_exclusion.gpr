with "config/protected_objects_and_mutual_exclusion_config.gpr";
project Protected_Objects_And_Mutual_Exclusion is

   for Source_Dirs use ("src/", "config/");
   for Object_Dir use "obj/" & Protected_Objects_And_Mutual_Exclusion_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("protected_objects_and_mutual_exclusion.adb");

   package Compiler is
      for Default_Switches ("Ada") use Protected_Objects_And_Mutual_Exclusion_Config.Ada_Compiler_Switches;
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es"); --  Symbolic traceback
   end Binder;

   package Install is
      for Artifacts (".") use ("share");
   end Install;

end Protected_Objects_And_Mutual_Exclusion;
